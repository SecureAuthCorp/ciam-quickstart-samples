{
  "name": "@ciam-quickstart/angular-token-refresh",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "version": "0.0.1",
  "scripts": {
    "ensure-env": "test -f src/environments/environment.ts || cp src/environments/environment.example.ts src/environments/environment.ts",
    "start": "ng serve --ssl --port 4250",
    "build": "ng build",
    "build:ci": "yarn ensure-env && yarn build",
    "test": "ng test",
    "test:ci": "yarn ensure-env && yarn test",
    "format": "prettier --write --ignore-path=../../../.gitignore .",
    "format:check": "prettier --check --ignore-path=../../../.gitignore ."
  },
  "dependencies": {
    "@angular/common": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/forms": "22.0.5",
    "@angular/platform-browser": "22.0.5",
    "@angular/router": "22.0.5",
    "angular-auth-oidc-client": "21.0.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "resolutions": {
    "@angular/build/vite": "7.3.5",
    "vitest/vite": "8.0.16",
    "esbuild": "0.28.1",
    "@babel/core": "7.29.6"
  }
}

CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
ISSUER_URL=https://your-tenant.us.connect.secureauth.com/your-workspace
SCOPES=openid profile email

# These are for configuring your SecureAuth application registration.
# The sample derives the callback/logout paths from Spring Security's
# default options (redirect URI = /login/oauth2/code/{registrationId},
# post-logout = /), so it doesn't read these at runtime.
REDIRECT_URI=https://localhost:4260/login/oauth2/code/secureauth
POST_LOGOUT_URI=https://localhost:4260/

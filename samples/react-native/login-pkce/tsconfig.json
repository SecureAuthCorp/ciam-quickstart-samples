{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-native",
    "types": ["jest"]
  },
  "include": ["App.tsx", "index.js", "__tests__/**/*.ts", "__tests__/**/*.tsx"],
  "exclude": ["node_modules", "ios", "android"]
}
